//@version=6
// =============================================================================
// ICT/SMC Suite | Time & Sessions
// -----------------------------------------------------------------------------
// File:        indicators/04_time_sessions.pine
// Author:      arkcode369 (la51)
// License:     MIT
// Concepts:    docs/concepts/concept-logic.md
//                - Killzones, ICT Macros, Silver Bullet, Hours of Operation,
//                  NWOG / NDOG, CBDR, Asia Range, Day/Time Logic
//              docs/concepts/concept-crt.md
//                - Time Framework, 1-5-9 AM Cycle, Key Times (1, 3, 6, 8, 9, 11)
//              docs/concepts/concept-foundation-model.md
//                - Hourly Delivery, Intraweek/Intraday Reversal hours
//
// Drawn:
//   - Background tint for Asia, London, NY AM, NY PM killzones
//   - Vertical lines at ICT Macro starts (6 windows per day)
//   - Background tint for Silver Bullet hours (London / NY AM / NY PM)
//   - Asia / London / NY session range boxes (H–L of the session)
//   - CBDR (14:00–20:00 NY) range box
//   - NWOG line (Friday 16:00 NY close → Sunday 18:00 NY open)
//   - NDOG line (prev NY close → today's NY open)
//   - 1 / 5 / 9 AM EST candle markers (CRT key cycle)
//
// Repaint policy: NONE. All drawings are time-based, not price-based.
// =============================================================================

indicator(
     "ICT/SMC Suite | Time & Sessions",
     shorttitle = "ICT-TIME",
     overlay = true,
     max_boxes_count = 200,
     max_lines_count = 500,
     max_labels_count = 500
     )

// =============================================================================
// INPUTS
// =============================================================================

G_KZ      = "Killzones"
G_MACRO   = "Macros & Silver Bullet"
G_RANGE   = "Session Ranges"
G_GAPS    = "NWOG / NDOG"
G_CRT     = "CRT 1-5-9 AM"
G_DISP    = "Display"
G_ALERT   = "Alerts"

// --- Killzones ---
showAsia   = input.bool(true, "Show Asia killzone (20:00–00:00 NY)",  group = G_KZ)
showLondon = input.bool(true, "Show London killzone (02:00–05:00 NY)", group = G_KZ)
showNYAM   = input.bool(true, "Show NY AM killzone (07:00–10:00 NY)",  group = G_KZ)
showNYPM   = input.bool(true, "Show NY PM killzone (13:30–16:00 NY)",  group = G_KZ)

colAsia   = input.color(color.new(color.gray,    93), "Asia bg",  group = G_KZ, inline = "ka")
colLondon = input.color(color.new(color.aqua,    92), "London bg", group = G_KZ, inline = "ka")
colNYAM   = input.color(color.new(color.lime,    92), "NY AM bg", group = G_KZ, inline = "ka")
colNYPM   = input.color(color.new(color.orange,  92), "NY PM bg", group = G_KZ, inline = "ka")

// --- Macros & Silver Bullet ---
showMacros       = input.bool(true,  "Show ICT Macro starts (6/day)",      group = G_MACRO)
showSilverBullet = input.bool(true,  "Show Silver Bullet hours bg",         group = G_MACRO)
colMacro         = input.color(color.new(color.red, 30), "Macro line",      group = G_MACRO)
colSB            = input.color(color.new(color.silver, 90), "Silver Bullet bg", group = G_MACRO)

// --- Session ranges ---
showAsiaRange   = input.bool(true,  "Asia range box",   group = G_RANGE)
showLondonRange = input.bool(true,  "London range box", group = G_RANGE)
showNYRange     = input.bool(true,  "NY range box",     group = G_RANGE)
showCBDR        = input.bool(true,  "CBDR (14:00–20:00 NY) range box", group = G_RANGE)
maxRangeBoxes   = input.int(20, "Max range boxes kept", minval = 5, maxval = 100, group = G_RANGE)

colAsiaR   = input.color(color.new(color.gray,    80), "Asia range",   group = G_RANGE, inline = "rng")
colLondonR = input.color(color.new(color.aqua,    80), "London range", group = G_RANGE, inline = "rng")
colNYR     = input.color(color.new(color.lime,    80), "NY range",     group = G_RANGE, inline = "rng")
colCBDRR   = input.color(color.new(color.fuchsia, 80), "CBDR range",   group = G_RANGE, inline = "rng")

// --- Gaps ---
showNWOG = input.bool(true, "New Week Opening Gap (NWOG)",   group = G_GAPS)
showNDOG = input.bool(true, "New Day Opening Gap (NDOG)",    group = G_GAPS)
maxGaps  = input.int(8, "Max NWOG/NDOG kept", minval = 2, maxval = 30, group = G_GAPS)
colNWOG  = input.color(color.new(color.purple, 0), "NWOG color", group = G_GAPS)
colNDOG  = input.color(color.new(color.teal,   0), "NDOG color", group = G_GAPS)

// --- CRT 1-5-9 AM ---
showCRT  = input.bool(true,  "CRT 1/5/9 AM markers",        group = G_CRT)
colCRT   = input.color(color.new(color.yellow, 0), "CRT marker", group = G_CRT)

// --- Display ---
maxBars = input.int(2000,
            "Limit drawings to last N bars (0 = no limit)",
            minval = 0, maxval = 20000, group = G_DISP)

// --- Alerts ---
alertKZStart    = input.bool(false, "Alert at killzone open", group = G_ALERT)
alertSBStart    = input.bool(false, "Alert at Silver Bullet open", group = G_ALERT)
alertMacroStart = input.bool(false, "Alert at Macro open", group = G_ALERT)

// =============================================================================
// HELPERS
// =============================================================================

f_inSess(string sess) =>
    not na(time(timeframe.period, sess, "America/New_York"))

f_sessStart(string sess) =>
    bool inNow  = not na(time(timeframe.period, sess, "America/New_York"))
    bool inPrev = not na(time(timeframe.period, sess, "America/New_York")[1])
    inNow and not inPrev

f_sessEnd(string sess) =>
    bool inNow  = not na(time(timeframe.period, sess, "America/New_York"))
    bool inPrev = not na(time(timeframe.period, sess, "America/New_York")[1])
    not inNow and inPrev

f_drawingAllowed() =>
    maxBars == 0 or bar_index >= last_bar_index - maxBars

// =============================================================================
// KILLZONE BACKGROUNDS
// =============================================================================

bgcolor(showAsia   and f_inSess("2000-2400:23456") and f_drawingAllowed() ? colAsia   : na, title = "Asia KZ")
bgcolor(showLondon and f_inSess("0200-0500:23456") and f_drawingAllowed() ? colLondon : na, title = "London KZ")
bgcolor(showNYAM   and f_inSess("0700-1000:23456") and f_drawingAllowed() ? colNYAM   : na, title = "NY AM KZ")
bgcolor(showNYPM   and f_inSess("1330-1600:23456") and f_drawingAllowed() ? colNYPM   : na, title = "NY PM KZ")

// Killzone alerts
if alertKZStart and (f_sessStart("2000-2400:23456") or f_sessStart("0200-0500:23456") or
                     f_sessStart("0700-1000:23456") or f_sessStart("1330-1600:23456"))
    alert("Killzone open @ " + syminfo.ticker, alert.freq_once_per_bar_close)

// =============================================================================
// SILVER BULLET BACKGROUNDS
// =============================================================================

bool sbLondon = f_inSess("0300-0400:23456")
bool sbNYAM   = f_inSess("1000-1100:23456")
bool sbNYPM   = f_inSess("1400-1500:23456")
bgcolor(showSilverBullet and (sbLondon or sbNYAM or sbNYPM) and f_drawingAllowed() ? colSB : na, title = "Silver Bullet")

if alertSBStart and (f_sessStart("0300-0400:23456") or f_sessStart("1000-1100:23456") or f_sessStart("1400-1500:23456"))
    alert("Silver Bullet open @ " + syminfo.ticker, alert.freq_once_per_bar_close)

// =============================================================================
// MACRO START LINES (6 windows / day)
// =============================================================================

f_drawMacroLine(string sess, string label_text) =>
    if showMacros and f_sessStart(sess) and f_drawingAllowed()
        line.new(bar_index, low - ta.atr(14), bar_index, high + ta.atr(14),
             color = colMacro,
             style = line.style_dashed,
             extend = extend.none)
        label.new(bar_index, high + ta.atr(14), label_text,
             color = color.new(colMacro, 70),
             textcolor = color.white,
             style = label.style_label_down,
             size = size.tiny)
        if alertMacroStart
            alert("ICT Macro " + label_text + " @ " + syminfo.ticker, alert.freq_once_per_bar_close)

f_drawMacroLine("0950-1010:23456", "M1 09:50")
f_drawMacroLine("1050-1110:23456", "M2 10:50")
f_drawMacroLine("1150-1210:23456", "M3 11:50")
f_drawMacroLine("1310-1340:23456", "M4 13:10")
f_drawMacroLine("1450-1510:23456", "M5 14:50")
f_drawMacroLine("1515-1545:23456", "M6 15:15")

// =============================================================================
// SESSION RANGE BOXES
// =============================================================================

type RngBox
    int   start
    float h
    float l
    box   bx

var array<RngBox> ranges = array.new<RngBox>()

// Track current session high/low; create box when session ends
f_buildSessionBox(string sess, bool show, color cc, string title_) =>
    if show
        bool inNow = f_inSess(sess)
        bool started = f_sessStart(sess)
        bool ended   = f_sessEnd(sess)
        var float curH = na
        var float curL = na
        var int   curStart = na
        if started
            curH := high
            curL := low
            curStart := bar_index
        else if inNow
            curH := math.max(curH, high)
            curL := math.min(curL, low)
        if ended and not na(curStart)
            int leftBar = curStart
            box bx = box.new(leftBar, curH, bar_index - 1, curL,
                 border_color = color.new(cc, 30),
                 bgcolor = cc,
                 extend = extend.none)
            label.new(leftBar, curH, title_,
                 color = color.new(cc, 60),
                 textcolor = color.white,
                 style = label.style_label_lower_right,
                 size = size.tiny)
            RngBox rb = RngBox.new(leftBar, curH, curL, bx)
            array.push(ranges, rb)
            curStart := na

f_buildSessionBox("2000-2400:23456", showAsiaRange,   colAsiaR,   "Asia")
f_buildSessionBox("0200-0500:23456", showLondonRange, colLondonR, "London")
f_buildSessionBox("0700-1600:23456", showNYRange,     colNYR,     "NY")
f_buildSessionBox("1400-2000:23456", showCBDR,        colCBDRR,   "CBDR")

while array.size(ranges) > maxRangeBoxes
    RngBox r0 = array.shift(ranges)
    if not na(r0.bx)
        box.delete(r0.bx)

// =============================================================================
// NWOG / NDOG
// =============================================================================

type Gap
    float topPrice
    float botPrice
    int   leftBar
    bool  isWeek    // true = NWOG, false = NDOG
    box   bx
    line  midLn

var array<Gap> gaps = array.new<Gap>()
var float prevDayClose = na
var float prevWeekClose = na

// Track previous day's NY close (16:00 NY) and previous week's Friday close
bool atNYClose = hour(time, "America/New_York") == 16 and minute(time, "America/New_York") == 0
if atNYClose
    prevDayClose := close
    if dayofweek(time, "America/New_York") == dayofweek.friday
        prevWeekClose := close

// At new day open (NY 18:00 = start of new trading day per ICT convention),
// or simpler: midnight NY change → use trueDayOpen at 00:00
bool atDayOpen = hour(time, "America/New_York") == 0 and minute(time, "America/New_York") == 0
bool atWeekOpen = dayofweek(time, "America/New_York") == dayofweek.sunday and
                  hour(time, "America/New_York") == 18 and minute(time, "America/New_York") == 0

if showNDOG and atDayOpen and not na(prevDayClose) and f_drawingAllowed()
    float t = math.max(open, prevDayClose)
    float b = math.min(open, prevDayClose)
    if t != b
        box bx = box.new(bar_index, t, bar_index, b,
             border_color = color.new(colNDOG, 50),
             bgcolor = color.new(colNDOG, 80),
             extend = extend.right)
        line ln = line.new(bar_index, math.avg(t, b), bar_index, math.avg(t, b),
             color = color.new(colNDOG, 30),
             style = line.style_dashed,
             extend = extend.right)
        Gap g = Gap.new(t, b, bar_index, false, bx, ln)
        array.push(gaps, g)

if showNWOG and atWeekOpen and not na(prevWeekClose) and f_drawingAllowed()
    float t = math.max(open, prevWeekClose)
    float b = math.min(open, prevWeekClose)
    if t != b
        box bx = box.new(bar_index, t, bar_index, b,
             border_color = color.new(colNWOG, 50),
             bgcolor = color.new(colNWOG, 80),
             extend = extend.right)
        line ln = line.new(bar_index, math.avg(t, b), bar_index, math.avg(t, b),
             color = color.new(colNWOG, 30),
             style = line.style_dashed,
             extend = extend.right)
        Gap g = Gap.new(t, b, bar_index, true, bx, ln)
        array.push(gaps, g)

while array.size(gaps) > maxGaps
    Gap g0 = array.shift(gaps)
    if not na(g0.bx)
        box.delete(g0.bx)
    if not na(g0.midLn)
        line.delete(g0.midLn)

// =============================================================================
// CRT 1-5-9 AM markers
// =============================================================================

f_drawCRTMarker(int targetHour, string txt) =>
    if showCRT and hour(time, "America/New_York") == targetHour and minute(time, "America/New_York") == 0 and f_drawingAllowed()
        label.new(bar_index, low - ta.atr(14) * 0.5, txt,
             color = color.new(colCRT, 30),
             textcolor = color.black,
             style = label.style_label_up,
             size = size.tiny)

f_drawCRTMarker(1, "1AM")
f_drawCRTMarker(5, "5AM")
f_drawCRTMarker(9, "9AM")

// =============================================================================
// ALERT CONDITIONS (dropdown)
// =============================================================================
alertcondition(f_sessStart("0700-1000:23456"),  "NY AM open",     "NY AM open @ {{ticker}}")
alertcondition(f_sessStart("1000-1100:23456"),  "Silver Bullet NY AM", "SB NY AM open")
alertcondition(f_sessStart("1400-1500:23456"),  "Silver Bullet NY PM", "SB NY PM open")
alertcondition(f_sessStart("0950-1010:23456"),  "Macro 09:50",    "Macro 09:50 open")
alertcondition(f_sessStart("1050-1110:23456"),  "Macro 10:50",    "Macro 10:50 open")
