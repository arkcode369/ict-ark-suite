//@version=6
// =============================================================================
// ICT/SMC Suite | Malaysian SNR (Body-based S/R)
// -----------------------------------------------------------------------------
// File:        indicators/07_msnr.pine
// Author:      arkcode369 (la51)
// License:     MIT
// Concepts:    docs/concepts/concept-snr.md
//                - Body-based Support / Resistance (wicks ignored)
//                - Classical / Breakout / GAP S/R
//                - Fresh vs Unfresh (untested vs tested)
//                - Bullish / Bearish Engulfing
//                - QML (Quasimodo Level) — 3-bar reversal pattern
//                - Trendline approach (body-based)
//                - Storyline + Roadblocks logic
//
// Detected:
//   - Body-cluster S/R: groups of recent body extremes within ATR tolerance
//   - Fresh / Unfresh classification
//   - Broken level becomes opposite (Resistance → Support and vice versa)
//   - Bullish / Bearish Engulfing candles
//   - QML reversal levels (basic detector)
//
// v0.2 additions:
//   - HNS (Head & Shoulders) full pattern matcher (regular + inverse)
//   - Multi-trendline auto-fit (body-based, 3+ pivots)
//   - Storyline / Roadblocks ranking (classify S/R as active obstacles)
//
// Repaint policy: S/R levels stable once cluster confirms; cluster never
//   re-fires retroactively. Engulfing settled on close. QML settled after
//   3rd bar.
// =============================================================================

indicator(
     "ICT/SMC Suite | Malaysian SNR",
     shorttitle = "ICT-MSNR",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500
     )

// =============================================================================
// INPUTS
// =============================================================================

G_SR    = "Body-based S/R"
G_ENG   = "Engulfing"
G_QML   = "QML (Quasimodo Level)"
G_HNS   = "HNS (Head & Shoulders)"
G_TL    = "Multi-trendline"
G_STO   = "Storyline / Roadblocks"
G_DISP  = "Display"
G_ALERT = "Alerts"

showSR        = input.bool(true, "Show body-cluster S/R lines", group = G_SR)
clusterCount  = input.int(2,
                  "Min body-extreme cluster size",
                  minval = 2, maxval = 5, group = G_SR)
clusterTolATR = input.float(0.25,
                  "Cluster tolerance (× ATR14)",
                  minval = 0.05, maxval = 2.0, step = 0.05, group = G_SR)
srLookback    = input.int(40,
                  "Body lookback bars",
                  minval = 10, maxval = 200, group = G_SR)
maxSRLines    = input.int(20, "Max S/R lines kept", minval = 5, maxval = 100, group = G_SR)

colSup = input.color(color.new(color.lime, 0), "Support",    group = G_SR, inline = "src")
colRes = input.color(color.new(color.red,  0), "Resistance", group = G_SR, inline = "src")
colBrk = input.color(color.new(color.gray, 30), "Broken (flipped)", group = G_SR)

showEng    = input.bool(true, "Show engulfing markers", group = G_ENG)
engStrong  = input.float(0.0,
                  "Min engulf body ratio (current/prev)",
                  minval = 0.5, maxval = 5.0, step = 0.1,
                  group = G_ENG)
colEngBull = input.color(color.new(color.green, 0), "Bull engulf", group = G_ENG, inline = "eng")
colEngBear = input.color(color.new(color.red,   0), "Bear engulf", group = G_ENG, inline = "eng")

showQML = input.bool(true, "Show QML reversal levels", group = G_QML)
qmlMaxKept = input.int(15, "Max QML lines kept", minval = 3, maxval = 50, group = G_QML)
colQMLBull = input.color(color.new(color.aqua,    0), "QML bull", group = G_QML, inline = "qml")
colQMLBear = input.color(color.new(color.fuchsia, 0), "QML bear", group = G_QML, inline = "qml")

maxBars = input.int(2000, "Limit drawings to last N bars (0 = no limit)",
                    minval = 0, maxval = 20000, group = G_DISP)

alertSR  = input.bool(true, "Alert when S/R level forms",  group = G_ALERT)
alertEng = input.bool(true, "Alert on engulfing candle",   group = G_ALERT)
alertQML = input.bool(true, "Alert on QML formation",      group = G_ALERT)
alertHNS = input.bool(true, "Alert on HNS neckline break", group = G_ALERT)

// --- HNS ---
showHNS    = input.bool(true,  "Show HNS / Inverse HNS", group = G_HNS)
hnsTol     = input.float(0.4,
                  "Shoulder symmetry tolerance (× head height)",
                  minval = 0.05, maxval = 1.0, step = 0.05, group = G_HNS)
hnsMinHeight = input.float(0.3,
                  "Min head height (× ATR14)",
                  minval = 0.1, maxval = 5.0, step = 0.1, group = G_HNS)
maxHNS     = input.int(8, "Max HNS patterns kept",
                  minval = 1, maxval = 30, group = G_HNS)
colHNSBear = input.color(color.new(color.red,    20), "HNS bear", group = G_HNS, inline = "hns")
colHNSBull = input.color(color.new(color.green,  20), "HNS bull", group = G_HNS, inline = "hns")

// --- Multi-trendline ---
showTL    = input.bool(true,  "Show body-based trendlines", group = G_TL)
tlPivots  = input.int(3, "Min pivots to confirm trendline",
                  minval = 2, maxval = 6, group = G_TL)
tlLookback = input.int(60, "Pivot lookback bars",
                  minval = 20, maxval = 300, group = G_TL)
tlPivotLB  = input.int(3, "Pivot half-width",
                  minval = 2, maxval = 10, group = G_TL)
maxTL      = input.int(4, "Max trendlines kept (each direction)",
                  minval = 1, maxval = 10, group = G_TL)
colTLDown  = input.color(color.new(color.red,    20), "Down TL", group = G_TL, inline = "tl")
colTLUp    = input.color(color.new(color.lime,   20), "Up TL",   group = G_TL, inline = "tl")

// --- Storyline / Roadblocks ---
showSto      = input.bool(true,  "Highlight S/R as active roadblocks", group = G_STO)
rbDistATR    = input.float(2.0,
                  "Roadblock distance (× ATR14)",
                  minval = 0.2, maxval = 10.0, step = 0.1, group = G_STO)
rbFreshOnly  = input.bool(true,  "Only fresh levels qualify",        group = G_STO)
colRoadblock = input.color(color.new(color.yellow, 0), "Roadblock highlight", group = G_STO)

// =============================================================================
// HELPERS
// =============================================================================

f_drawingAllowed() => maxBars == 0 or bar_index >= last_bar_index - maxBars
atrV = ta.atr(14)

f_bodyHigh() => math.max(open, close)
f_bodyLow()  => math.min(open, close)

// =============================================================================
// TYPES
// =============================================================================

type SR
    float price
    int   bar
    bool  resistance      // true = R, false = S
    bool  fresh          = true
    bool  flipped        = false
    line  ln
    label lb

var array<SR> srList = array.new<SR>()

// =============================================================================
// BODY CLUSTER S/R DETECTION
// -----------------------------------------------------------------------------
// Look back srLookback bars; find tops (body-high) that have ≥ clusterCount
// occurrences within clusterTolATR × ATR. Same for body-low (support).
// Drawn at the median of cluster.
// =============================================================================

f_findCluster(bool wantHighs) =>
    float tol = clusterTolATR * atrV
    int   bestCount = 0
    float bestPrice = na
    int   bestBar   = na
    for i = 2 to srLookback
        float anchor = wantHighs ? f_bodyHigh()[i] : f_bodyLow()[i]
        int   cnt    = 1
        float sum    = anchor
        for j = 2 to srLookback
            if j != i
                float p = wantHighs ? f_bodyHigh()[j] : f_bodyLow()[j]
                if math.abs(p - anchor) <= tol
                    cnt += 1
                    sum += p
        if cnt > bestCount and cnt >= clusterCount
            bestCount := cnt
            bestPrice := sum / cnt
            bestBar   := bar_index - i
    [bestPrice, bestBar, bestCount]

f_levelExists(float price, float tol) =>
    bool exists = false
    if array.size(srList) > 0
        for k = 0 to array.size(srList) - 1
            SR s = array.get(srList, k)
            if math.abs(s.price - price) <= tol
                exists := true
                break
    exists

f_addSR(float price, int barAt, bool isRes) =>
    if not f_levelExists(price, clusterTolATR * atrV)
        color cc = isRes ? colRes : colSup
        line ln = line.new(barAt, price, bar_index, price,
             color = cc,
             style = line.style_solid,
             width = 1,
             extend = extend.right)
        label lb = label.new(bar_index, price,
             (isRes ? "R" : "S") + " (fresh)",
             color = color.new(cc, 80),
             textcolor = cc,
             style = label.style_label_left,
             size = size.tiny)
        SR s = SR.new(price, barAt, isRes, true, false, ln, lb)
        array.push(srList, s)
        if alertSR
            alert((isRes ? "Resistance" : "Support") + " formed @ " +
                  str.tostring(price), alert.freq_once_per_bar_close)
        while array.size(srList) > maxSRLines
            SR s0 = array.shift(srList)
            if not na(s0.ln)
                line.delete(s0.ln)
            if not na(s0.lb)
                label.delete(s0.lb)

if showSR and barstate.isconfirmed and bar_index > srLookback
    [resPrice, resBar, resCnt] = f_findCluster(true)
    [supPrice, supBar, supCnt] = f_findCluster(false)
    if not na(resPrice) and resCnt >= clusterCount
        f_addSR(resPrice, resBar, true)
    if not na(supPrice) and supCnt >= clusterCount
        f_addSR(supPrice, supBar, false)

// Update fresh/unfresh + flipped state for all S/R lines
if barstate.isconfirmed and array.size(srList) > 0
    for k = 0 to array.size(srList) - 1
        SR s = array.get(srList, k)
        if not s.flipped
            // Fresh check: body crossed level
            if s.resistance
                if f_bodyHigh() > s.price
                    s.flipped := true
                    s.resistance := false
                    if not na(s.ln)
                        line.set_color(s.ln, colBrk)
                    if not na(s.lb)
                        label.set_text(s.lb, "S (flipped)")
                else if s.fresh and high >= s.price
                    s.fresh := false
                    if not na(s.lb)
                        label.set_text(s.lb, "R")
            else
                if f_bodyLow() < s.price
                    s.flipped := true
                    s.resistance := true
                    if not na(s.ln)
                        line.set_color(s.ln, colBrk)
                    if not na(s.lb)
                        label.set_text(s.lb, "R (flipped)")
                else if s.fresh and low <= s.price
                    s.fresh := false
                    if not na(s.lb)
                        label.set_text(s.lb, "S")
        if not na(s.ln)
            line.set_x2(s.ln, bar_index)
        if not na(s.lb)
            label.set_x(s.lb, bar_index)

// =============================================================================
// ENGULFING DETECTION
// =============================================================================

if showEng and barstate.isconfirmed
    float prevBody = math.abs(close[1] - open[1])
    float curBody  = math.abs(close - open)
    bool minRatioOK = engStrong == 0.0 or curBody >= engStrong * prevBody
    bool bullEng = close > open and close[1] < open[1] and
                   close >= open[1] and open <= close[1] and minRatioOK
    bool bearEng = close < open and close[1] > open[1] and
                   close <= open[1] and open >= close[1] and minRatioOK
    if (bullEng or bearEng) and f_drawingAllowed()
        color cc = bullEng ? colEngBull : colEngBear
        label.new(bar_index, bullEng ? low - atrV * 0.3 : high + atrV * 0.3,
             bullEng ? "ENG↑" : "ENG↓",
             color = color.new(cc, 30),
             textcolor = color.white,
             style = bullEng ? label.style_label_up : label.style_label_down,
             size = size.tiny)
        if alertEng
            alert((bullEng ? "Bullish" : "Bearish") + " engulfing @ " + syminfo.ticker,
                  alert.freq_once_per_bar_close)

// =============================================================================
// QML (Quasimodo Level) DETECTION
// -----------------------------------------------------------------------------
// Bullish QML setup (3-pivot pattern):
//   pivot1 = swing low (anchor)
//   pivot2 = swing high higher than prior
//   pivot3 = swing low lower than pivot1 (Quasimodo break)
// Reversal signal at pivot2 level.
// =============================================================================

type Qml
    float price
    int   bar
    bool  bullish    // bullish QML (long entry off pivot2)
    line  ln
    label lb

var array<Qml> qmls = array.new<Qml>()

// Use 3-bar pivots for simplicity
f_isPH(simple int lb) =>
    bool ok = true
    for i = 0 to lb * 2
        if i != lb and high[i] > high[lb]
            ok := false
            break
    ok

f_isPL(simple int lb) =>
    bool ok = true
    for i = 0 to lb * 2
        if i != lb and low[i] < low[lb]
            ok := false
            break
    ok

var float ph1 = na
var float pl1 = na
var float pl0 = na

if barstate.isconfirmed
    if f_isPL(3)
        // Track sequence: pl0 (oldest) -> ph1 (middle) -> pl1 (newest, the Quasi break)
        if not na(pl0) and not na(ph1) and low[3] < pl0
            // Bullish QML: pivot2 = ph1 (the high between two lows)
            if showQML and f_drawingAllowed()
                line ln = line.new(bar_index - 3, ph1, bar_index, ph1,
                     color = colQMLBull,
                     style = line.style_dashed,
                     extend = extend.right)
                label lb = label.new(bar_index, ph1, "QML↑",
                     color = color.new(colQMLBull, 70),
                     textcolor = color.white,
                     style = label.style_label_left,
                     size = size.tiny)
                Qml q = Qml.new(ph1, bar_index - 3, true, ln, lb)
                array.push(qmls, q)
                if alertQML
                    alert("Bullish QML @ " + str.tostring(ph1), alert.freq_once_per_bar_close)
        pl0 := pl1
        pl1 := low[3]
    if f_isPH(3)
        ph1 := high[3]

while array.size(qmls) > qmlMaxKept
    Qml q0 = array.shift(qmls)
    if not na(q0.ln)
        line.delete(q0.ln)
    if not na(q0.lb)
        label.delete(q0.lb)

// =============================================================================
// HNS / INVERSE HNS DETECTION
// -----------------------------------------------------------------------------
// Regular HNS (bearish):
//   pivot1 = LS (left shoulder swing high)
//   valley1 = swing low between LS and head
//   pivot2 = head (higher swing high)
//   valley2 = swing low between head and RS
//   pivot3 = RS (lower swing high, similar height to LS within hnsTol × headHeight)
//   neckline = line through valley1, valley2
//   confirmation = close < neckline value at current bar
//
// Inverse HNS (bullish): mirror on lows.
// =============================================================================

type Hns
    int   ls
    int   head
    int   rs
    int   v1
    int   v2
    float lsP
    float headP
    float rsP
    float v1P
    float v2P
    bool  bearish
    bool  confirmed
    line  neckLn
    label lbl

var array<Hns> hnsList = array.new<Hns>()

// Track recent swing highs/lows (offset 3-pivots)
var array<int>   recentHi   = array.new<int>()
var array<float> recentHiP  = array.new<float>()
var array<int>   recentLo   = array.new<int>()
var array<float> recentLoP  = array.new<float>()

if barstate.isconfirmed
    if f_isPH(3)
        array.push(recentHi,  bar_index - 3)
        array.push(recentHiP, high[3])
        if array.size(recentHi) > 20
            array.shift(recentHi)
            array.shift(recentHiP)
    if f_isPL(3)
        array.push(recentLo,  bar_index - 3)
        array.push(recentLoP, low[3])
        if array.size(recentLo) > 20
            array.shift(recentLo)
            array.shift(recentLoP)

// Detect regular HNS (3 most recent highs + 2 most recent lows between)
if showHNS and barstate.isconfirmed and array.size(recentHi) >= 3 and array.size(recentLo) >= 2
    int n = array.size(recentHi)
    float lsP   = array.get(recentHiP, n - 3)
    float headP = array.get(recentHiP, n - 2)
    float rsP   = array.get(recentHiP, n - 1)
    int   lsB   = array.get(recentHi,  n - 3)
    int   hdB   = array.get(recentHi,  n - 2)
    int   rsB   = array.get(recentHi,  n - 1)
    int   nl    = array.size(recentLo)
    float v1P   = array.get(recentLoP, nl - 2)
    float v2P   = array.get(recentLoP, nl - 1)
    int   v1B   = array.get(recentLo,  nl - 2)
    int   v2B   = array.get(recentLo,  nl - 1)
    if v1B > lsB and v1B < hdB and v2B > hdB and v2B < rsB
        float headHeight = math.min(headP - lsP, headP - rsP)
        bool isHigherHead = headP > lsP and headP > rsP
        bool shoulderSym  = math.abs(lsP - rsP) <= hnsTol * headHeight
        bool minHt        = headHeight >= hnsMinHeight * atrV
        if isHigherHead and shoulderSym and minHt
            // Already captured?
            bool dup = false
            if array.size(hnsList) > 0
                Hns last = array.get(hnsList, array.size(hnsList) - 1)
                if last.bearish and last.head == hdB and last.rs == rsB
                    dup := true
            if not dup
                // Project neckline value at current bar
                float slope = v2P - v1P
                float run   = v2B - v1B
                float necklineNow = run == 0 ? v2P : v2P + slope * (bar_index - v2B) / run
                bool broken = close < necklineNow
                if f_drawingAllowed()
                    line ln = line.new(v1B, v1P, bar_index, necklineNow,
                         color = colHNSBear,
                         style = line.style_dashed,
                         width = 2)
                    label lb = label.new(rsB, rsP,
                         "HNS" + (broken ? " ✓" : ""),
                         color = color.new(colHNSBear, 60),
                         textcolor = color.white,
                         style = label.style_label_down,
                         size = size.small)
                    Hns h = Hns.new(lsB, hdB, rsB, v1B, v2B, lsP, headP, rsP, v1P, v2P,
                                    true, broken, ln, lb)
                    array.push(hnsList, h)
                if broken and alertHNS
                    alert("HNS confirmed @ " + str.tostring(close), alert.freq_once_per_bar_close)

// Detect inverse HNS (3 most recent lows + 2 most recent highs between)
if showHNS and barstate.isconfirmed and array.size(recentLo) >= 3 and array.size(recentHi) >= 2
    int n = array.size(recentLo)
    float lsP   = array.get(recentLoP, n - 3)
    float headP = array.get(recentLoP, n - 2)
    float rsP   = array.get(recentLoP, n - 1)
    int   lsB   = array.get(recentLo,  n - 3)
    int   hdB   = array.get(recentLo,  n - 2)
    int   rsB   = array.get(recentLo,  n - 1)
    int   nh    = array.size(recentHi)
    float v1P   = array.get(recentHiP, nh - 2)
    float v2P   = array.get(recentHiP, nh - 1)
    int   v1B   = array.get(recentHi,  nh - 2)
    int   v2B   = array.get(recentHi,  nh - 1)
    if v1B > lsB and v1B < hdB and v2B > hdB and v2B < rsB
        float headHeight = math.min(lsP - headP, rsP - headP)
        bool isLowerHead = headP < lsP and headP < rsP
        bool shoulderSym = math.abs(lsP - rsP) <= hnsTol * headHeight
        bool minHt       = headHeight >= hnsMinHeight * atrV
        if isLowerHead and shoulderSym and minHt
            bool dup = false
            if array.size(hnsList) > 0
                Hns last = array.get(hnsList, array.size(hnsList) - 1)
                if not last.bearish and last.head == hdB and last.rs == rsB
                    dup := true
            if not dup
                float slope = v2P - v1P
                float run   = v2B - v1B
                float necklineNow = run == 0 ? v2P : v2P + slope * (bar_index - v2B) / run
                bool broken = close > necklineNow
                if f_drawingAllowed()
                    line ln = line.new(v1B, v1P, bar_index, necklineNow,
                         color = colHNSBull,
                         style = line.style_dashed,
                         width = 2)
                    label lb = label.new(rsB, rsP,
                         "iHNS" + (broken ? " ✓" : ""),
                         color = color.new(colHNSBull, 60),
                         textcolor = color.white,
                         style = label.style_label_up,
                         size = size.small)
                    Hns h = Hns.new(lsB, hdB, rsB, v1B, v2B, lsP, headP, rsP, v1P, v2P,
                                    false, broken, ln, lb)
                    array.push(hnsList, h)
                if broken and alertHNS
                    alert("Inverse HNS confirmed @ " + str.tostring(close), alert.freq_once_per_bar_close)

while array.size(hnsList) > maxHNS
    Hns h0 = array.shift(hnsList)
    if not na(h0.neckLn)
        line.delete(h0.neckLn)
    if not na(h0.lbl)
        label.delete(h0.lbl)

// =============================================================================
// MULTI-TRENDLINE AUTO-FIT
// -----------------------------------------------------------------------------
// Collect last N body pivots (body-high for downtrend, body-low for uptrend),
// fit a line through 3+ that all sit on the same side: descending series
// for downtrend, ascending for uptrend. Use simple greedy: take oldest pivot,
// pair with newest, check if intermediate pivots also fit within ATR/2.
// =============================================================================

type Tl
    int   bar1
    int   bar2
    float p1
    float p2
    bool  isDown
    line  ln

var array<Tl> tls = array.new<Tl>()

// We re-detect every N bars to avoid over-drawing; here we redetect on every
// confirmed pivot.
f_collectBodyPivots(bool wantHigh) =>
    array<int>   bArr = array.new<int>()
    array<float> pArr = array.new<float>()
    for k = tlPivotLB to math.min(tlLookback, bar_index)
        bool ok = true
        for j = -tlPivotLB to tlPivotLB
            if j != 0
                int kk = k + j
                if kk >= 0
                    if wantHigh
                        if f_bodyHigh()[kk] > f_bodyHigh()[k]
                            ok := false
                            break
                    else
                        if f_bodyLow()[kk] < f_bodyLow()[k]
                            ok := false
                            break
        if ok
            array.push(bArr, bar_index - k)
            array.push(pArr, wantHigh ? f_bodyHigh()[k] : f_bodyLow()[k])
    [bArr, pArr]

if showTL and barstate.isconfirmed and bar_index > tlLookback
    [hiBars, hiPrices] = f_collectBodyPivots(true)
    [loBars, loPrices] = f_collectBodyPivots(false)
    // Downtrend: pair oldest hi with most recent hi where price is lower
    if array.size(hiBars) >= tlPivots
        // Use first (oldest) and last (newest) pivots in window
        int b1 = array.get(hiBars, 0)
        int b2 = array.get(hiBars, array.size(hiBars) - 1)
        float p1 = array.get(hiPrices, 0)
        float p2 = array.get(hiPrices, array.size(hiPrices) - 1)
        if p2 < p1 and b2 > b1
            // Verify intermediate pivots fit (within tolerance)
            float slope = (p2 - p1) / float(b2 - b1)
            int ok = 0
            int total = array.size(hiBars)
            for kk = 0 to total - 1
                int bb = array.get(hiBars, kk)
                float pp = array.get(hiPrices, kk)
                float lineP = p1 + slope * (bb - b1)
                if math.abs(pp - lineP) <= atrV * 0.5
                    ok += 1
            if ok >= tlPivots
                bool dup = false
                if array.size(tls) > 0
                    for kk = 0 to array.size(tls) - 1
                        Tl t = array.get(tls, kk)
                        if t.isDown and t.bar1 == b1 and t.bar2 == b2
                            dup := true
                            break
                if not dup and f_drawingAllowed()
                    line ln = line.new(b1, p1, b2, p2,
                         color = colTLDown,
                         style = line.style_solid,
                         width = 2,
                         extend = extend.right)
                    array.push(tls, Tl.new(b1, b2, p1, p2, true, ln))
    if array.size(loBars) >= tlPivots
        int b1 = array.get(loBars, 0)
        int b2 = array.get(loBars, array.size(loBars) - 1)
        float p1 = array.get(loPrices, 0)
        float p2 = array.get(loPrices, array.size(loPrices) - 1)
        if p2 > p1 and b2 > b1
            float slope = (p2 - p1) / float(b2 - b1)
            int ok = 0
            int total = array.size(loBars)
            for kk = 0 to total - 1
                int bb = array.get(loBars, kk)
                float pp = array.get(loPrices, kk)
                float lineP = p1 + slope * (bb - b1)
                if math.abs(pp - lineP) <= atrV * 0.5
                    ok += 1
            if ok >= tlPivots
                bool dup = false
                if array.size(tls) > 0
                    for kk = 0 to array.size(tls) - 1
                        Tl t = array.get(tls, kk)
                        if not t.isDown and t.bar1 == b1 and t.bar2 == b2
                            dup := true
                            break
                if not dup and f_drawingAllowed()
                    line ln = line.new(b1, p1, b2, p2,
                         color = colTLUp,
                         style = line.style_solid,
                         width = 2,
                         extend = extend.right)
                    array.push(tls, Tl.new(b1, b2, p1, p2, false, ln))

// Prune: keep newest maxTL per direction
while array.size(tls) > maxTL * 2
    Tl t0 = array.shift(tls)
    if not na(t0.ln)
        line.delete(t0.ln)

// =============================================================================
// STORYLINE / ROADBLOCKS
// -----------------------------------------------------------------------------
// Walk active SR list; mark levels within rbDistATR × ATR14 of current close
// as "active roadblocks" (line width bumped + label highlighted).
// =============================================================================

if showSto and barstate.isconfirmed and array.size(srList) > 0
    for k = 0 to array.size(srList) - 1
        SR s = array.get(srList, k)
        bool nearby = math.abs(close - s.price) <= rbDistATR * atrV
        bool qualifies = nearby and (rbFreshOnly ? s.fresh : true) and not s.flipped
        if qualifies
            if not na(s.ln)
                line.set_width(s.ln, 3)
                line.set_color(s.ln, colRoadblock)
            if not na(s.lb)
                label.set_text(s.lb, (s.resistance ? "R★" : "S★") + " ROADBLOCK")
                label.set_color(s.lb, color.new(colRoadblock, 30))

// =============================================================================
// ALERT CONDITIONS
// =============================================================================

alertcondition(barstate.isconfirmed and close > open and close[1] < open[1] and
               close >= open[1] and open <= close[1],
               "Bullish Engulfing", "Bull engulf @ {{ticker}}")
alertcondition(barstate.isconfirmed and close < open and close[1] > open[1] and
               close <= open[1] and open >= close[1],
               "Bearish Engulfing", "Bear engulf @ {{ticker}}")
